# Self-hosted PeerJS signaling
VITE_PEER_HOST=game.example.com
VITE_PEER_PORT=443
VITE_PEER_PATH=/
VITE_PEER_SECURE=true
VITE_ICE_API_URL=https://game.example.com/api/ice
VITE_WS_RELAY_URL=wss://game.example.com/ws-relay
VITE_MWC_WS_URL=wss://game.example.com/mwc

# JSON array string consumed by src/net/session.ts
# DIRECT mode still falls back to public PeerJS + browser STUN.
VITE_ICE_SERVERS=[{"urls":["stun:203.0.113.10:3478"]},{"urls":["turns:game.example.com:5349?transport=tcp","turn:203.0.113.10:3478?transport=tcp","turn:203.0.113.10:3478?transport=udp"],"username":"lwc2","credential":"CHANGE_ME_TURN_PASSWORD"}]
